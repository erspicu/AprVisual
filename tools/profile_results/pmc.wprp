<?xml version="1.0" encoding="utf-8"?>
<WindowsPerformanceRecorder Version="1.0" Author="Claude" Comments="PMC counters">
  <Profiles>
    <SystemCollector Id="SC_PMC" Name="PMCCollector">
      <BufferSize Value="1024"/>
      <Buffers Value="100"/>
    </SystemCollector>
    <SystemProvider Id="SP_PMC">
      <Keywords Operation="Add">
        <Keyword Value="CpuConfig"/>
        <Keyword Value="ProcessThread"/>
        <Keyword Value="Loader"/>
        <Keyword Value="SampledProfile"/>
        <Keyword Value="PmcProfile"/>
      </Keywords>
    </SystemProvider>
    <Profile Id="PMC.Verbose.File" Name="PMC" Description="PMC" LoggingMode="File" DetailLevel="Verbose">
      <Collectors>
        <SystemCollectorId Value="SC_PMC">
          <SystemProviderId Value="SP_PMC"/>
        </SystemCollectorId>
      </Collectors>
    </Profile>
  </Profiles>
</WindowsPerformanceRecorder>
