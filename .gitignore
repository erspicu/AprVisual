# 註：tools/knowledgebase/message/（gemini_query.py 的問答 log）刻意 *不* ignore —— 有參考價值，整個 tools/ 都入版控（user 指定）

# --- Claude Code 本機狀態 ---
.claude/

# benchmark staging output (build_benchmark.bat)
AprVisualBenchMark/

# self-hosted PHP portal (deployed manually to user's PHP host; may hold filled-in config)
WebSitePHP/

# release/update workflow notes — holds deployment credentials (FTP etc.); NEVER commit
workflow/

# private working copy (local snapshots) — not version-controlled
private/

# WLA DX — third-party assembler (binaries + docs); vendored locally, not version-controlled
# (exception to "all of tools/ is tracked"; it's an external tool, like ref/)
tools/wla-dx/

# compiled native static libs — build artifacts (e.g. AluBlock.lib), regenerable
*.lib

# PerfView (Microsoft profiler, ~24 MB binary + unpacked support files) — tool, not source
tools/perfview/

__pycache__/

# perf workflow caches (regenerable / large)
tools/perf/releases/
tools/perf/raw/
tools/perf/out/

# but DO track the deployed per-platform perf data (the global `x64/` rule above hides it,
# so re-include the dir + its json to match arm64 — this is the source of /version/'s chart)
!tools/perf/web/x64/
!tools/perf/web/x64/*.json
AprNesRef/
AC_ref/
TriCNES_ref/

# AccuracyCoin unattended-ROM work: holds a fork of 100thCoin/AccuracyCoin (MIT).
# Its own git repo lives inside — repo A must not track or embed it.
AprAccuracyCoinUnattended/
ref/VisualNes/
